# CodeQuest Backend - Environment variables
# Copy to .env and fill in values

# Database (PostgreSQL). Use async driver URL for async SQLAlchemy.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/codequest

# Sync URL for Alembic migrations (Alembic uses sync driver)
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/codequest

# App
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# JWT (used from Milestone 5)
# SECRET_KEY=your-secret-key-min-32-chars
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
